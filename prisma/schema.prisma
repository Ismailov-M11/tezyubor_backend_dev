generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  role      String   @default("admin")
  createdAt DateTime @default(now())
}

model Role {
  id          String          @id @default(cuid())
  name        String          @unique
  permissions String[]
  isActive    Boolean         @default(true)
  users       AdminUserRole[]
  createdAt   DateTime        @default(now())
}

model AdminUser {
  id               String          @id @default(cuid())
  name             String
  email            String          @unique
  password         String
  isActive         Boolean         @default(true)
  roles            AdminUserRole[]
  createdPharmacies Pharmacy[]     @relation("PharmacyCreatedBy")
  createdAt        DateTime        @default(now())
}

model AdminUserRole {
  userId String
  roleId String
  user   AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  role   Role      @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
}

model Owner {
  id         String     @id @default(cuid())
  name       String
  phone      String?
  email      String?
  login      String     @unique
  password   String
  isActive   Boolean    @default(true)
  createdAt  DateTime   @default(now())
  pharmacies Pharmacy[] @relation("OwnerPharmacies")
}

model Pharmacy {
  id                   String                @id @default(cuid())
  name                 String
  ownerName            String?
  email                String?
  address              String?
  phone                String
  lat                  Float?
  lng                  Float?
  login                String                @unique
  password             String
  isActive             Boolean               @default(true)
  requiresLocation     Boolean               @default(false)
  subscriptionExpiry   DateTime?
  allowedCouriers      String                @default("yandex,noor,millennium")
  city                 String?
  district             String?
  noorPaymentType      String                @default("CASH")
  balance              Float                 @default(100000)
  selfRegistered       Boolean               @default(false)
  createdById          String?
  createdBy            AdminUser?            @relation("PharmacyCreatedBy", fields: [createdById], references: [id], onDelete: SetNull)
  owners               Owner[]               @relation("OwnerPharmacies")
  createdAt            DateTime              @default(now())
  orders               Order[]
  subscriptionPayments SubscriptionPayment[]
  partnerShop          PartnerShop?          @relation("PharmacyPartnerShop")
}

model SubscriptionPayment {
  id         String    @id @default(cuid())
  pharmacyId String
  pharmacy   Pharmacy  @relation(fields: [pharmacyId], references: [id])
  invoiceId  String    @unique
  amount     Int
  status     String    @default("pending")
  createdAt  DateTime  @default(now())
  paidAt     DateTime?
}

model Order {
  id              String      @id @default(cuid())
  token           String      @unique
  pharmacyId      String?
  pharmacy        Pharmacy?   @relation(fields: [pharmacyId], references: [id])
  partnerId       String?
  partner         Partner?    @relation("PartnerOrders", fields: [partnerId], references: [id])
  partnerShopId   String?
  partnerShop     PartnerShop? @relation("PartnerShopOrders", fields: [partnerShopId], references: [id])
  actualDeliveryPrice Float?
  markupAmount        Float?
  status          OrderStatus @default(pending)
  pharmacyComment String?
  medicinesTotal  Float    @default(0)
  goodsComment    String?

  customerName    String?
  customerPhone   String?
  customerAddress String?
  apartment       String?
  entrance        String?
  floor           String?
  intercom        String?
  customerComment String?
  customerLat     Float?
  customerLng     Float?

  senderName      String?
  senderPhone     String?
  senderAddress   String?
  senderLat       Float?
  senderLng       Float?

  selectedCourier CourierType?
  deliveryPrice   Float?
  trackingUrl     String?
  totalPrice      Float?
  paymentType     String       @default("CASH")
  noorOrderId        Int?
  noorDisplayId      Int?
  millenniumOrderId  Int?
  mytaxiOrderId      Int?

  statusLogs OrderStatusLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model OrderStatusLog {
  id          String       @id @default(cuid())
  orderId     String
  order       Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  status      OrderStatus
  source      CourierType?
  actor       String?
  actorName   String?
  actorPhone  String?
  rawStatus   String?
  createdAt   DateTime     @default(now())
}

enum OrderStatus {
  pending
  awaiting_confirmation
  confirmed
  courier_pickup
  courier_picked
  courier_delivery
  delivered
  cancelled
}

enum CourierType {
  yandex
  noor
  millennium
  mytaxi
}

enum PartnerType {
  MARKETPLACE
  POST_SYSTEM
}

model Partner {
  id          String      @id @default(cuid())
  name        String
  type        PartnerType
  apiToken    String      @unique
  phone       String?
  address     String?
  lat         Float?
  lng         Float?
  balance     Float       @default(0)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  courierMarkups PartnerCourierMarkup[]
  shops          PartnerShop[]
  orders         Order[]                @relation("PartnerOrders")
}

model PartnerCourierMarkup {
  id            String      @id @default(cuid())
  partnerId     String
  partner       Partner     @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  courierType   CourierType
  markupPercent Float       @default(0)
  isEnabled     Boolean     @default(true)

  @@unique([partnerId, courierType])
}

model PartnerShop {
  id             String    @id @default(cuid())
  partnerId      String
  partner        Partner   @relation(fields: [partnerId], references: [id], onDelete: Cascade)
  pharmacyId     String?   @unique
  pharmacy       Pharmacy? @relation("PharmacyPartnerShop", fields: [pharmacyId], references: [id], onDelete: SetNull)
  externalShopId String?
  name           String
  phone          String?
  address        String?
  lat            Float?
  lng            Float?
  balance        Float     @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  orders         Order[]   @relation("PartnerShopOrders")

  @@unique([partnerId, externalShopId])
}
